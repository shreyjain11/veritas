{
  "name": "veritas-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "gen:types": "json2ts -i ../schema/audit-report.schema.json -o lib/audit-report.ts --bannerComment \"/* GENERATED from schema/audit-report.schema.json by 'npm run gen:types'. Do not edit. */\"",
    "typecheck": "tsc -p tsconfig.gate.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "ajv": "^8.17.1",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
